# Public site URL - set to your production origin (controls canonical,
# sitemap, and robots indexing).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API origin for the dev-only /api/* rewrite (see next.config.ts). In prod the
# API is served same-origin, so this is unused there.
BACKEND_URL=http://127.0.0.1:3001

# Google Search Console verification token (production only).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Umami analytics. Tracker is served first-party at /s.js; events POST to a
# same-origin path (/analytics/api/send), so no third-party host is referenced
# client-side. No-op when the id is unset.
NEXT_PUBLIC_UMAMI_SRC=/s.js
NEXT_PUBLIC_UMAMI_HOST_URL=/analytics
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
